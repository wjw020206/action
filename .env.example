# IPTV 下载地址
IPTV_LINK=

# 腾讯云 SecretId
COS_SECRET_ID=

# 腾讯云 SecretKey
COS_SECRET_KEY=

# COS 存储桶名称
COS_BUCKET=

# COS 存储桶地域
COS_REGION=

# 是否启用错误邮件提醒
EMAIL_NOTIFY=false

# SMTP 服务器地址
SMTP_HOST=

# SMTP 服务器端口
SMTP_PORT=465

# 是否使用 SSL
SMTP_SECURE=true

# SMTP 登录账号
SMTP_USER=

# SMTP 登录密码或授权码
SMTP_PASS=

# 发件人邮箱
MAIL_FROM=

# 收件人邮箱，多个用英文逗号分隔
MAIL_TO=
